<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.carewatch.features.report.controller.ReportsController">

    <!-- ScrollPane to allow scrolling if screen height is small -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" hbarPolicy="NEVER">
        <VBox spacing="20" style="-fx-padding: 30px 25px 25px 25px;">
            
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Reports &amp; Analytics" styleClass="title-label"/>
                    <Label text="Review patient telemetry statistics, search/filter historical trends, and export telemetry logs to CSV." styleClass="subtitle-label"/>
                </VBox>
            </HBox>

            <!-- Summary Cards FlowPane (3 cards per row) -->
            <FlowPane hgap="15" vgap="15" alignment="CENTER_LEFT">
                <VBox styleClass="info-card" prefWidth="210">
                    <Label text="Total Patients" styleClass="info-card-title"/>
                    <Label fx:id="txtTotalPatients" text="0" styleClass="info-card-value"/>
                </VBox>
                <VBox styleClass="info-card" prefWidth="210">
                    <Label text="Total Vitals" styleClass="info-card-title"/>
                    <Label fx:id="txtTotalVitals" text="0" styleClass="info-card-value"/>
                </VBox>
                <VBox styleClass="info-card" prefWidth="210">
                    <Label text="Critical Cases" styleClass="info-card-title"/>
                    <Label fx:id="txtCriticalCases" text="0" styleClass="info-card-value" style="-fx-text-fill: #ff7b72;"/>
                </VBox>
                <VBox styleClass="info-card" prefWidth="210">
                    <Label text="Warning Cases" styleClass="info-card-title"/>
                    <Label fx:id="txtWarningCases" text="0" styleClass="info-card-value" style="-fx-text-fill: #f0883b;"/>
                </VBox>
                <VBox styleClass="info-card" prefWidth="210">
                    <Label text="Resolved Cases" styleClass="info-card-title"/>
                    <Label fx:id="txtResolvedCases" text="0" styleClass="info-card-value" style="-fx-text-fill: #56d364;"/>
                </VBox>
                <VBox styleClass="info-card" prefWidth="210">
                    <Label text="Interventions" styleClass="info-card-title"/>
                    <Label fx:id="txtTotalInterventions" text="0" styleClass="info-card-value"/>
                </VBox>
            </FlowPane>

            <!-- Filters HBox -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="info-card">
                <TextField fx:id="searchField" promptText="Search patient name or email..." HBox.hgrow="ALWAYS" prefHeight="38" onKeyReleased="#handleSearchKeyPress"/>
                <ComboBox fx:id="urgencyFilterComboBox" onAction="#handleFilter" prefWidth="120" prefHeight="38"/>
                <DatePicker fx:id="startDatePicker" onAction="#handleFilter" prefWidth="130" prefHeight="38" promptText="Start Date"/>
                <DatePicker fx:id="endDatePicker" onAction="#handleFilter" prefWidth="130" prefHeight="38" promptText="End Date"/>
                <Button text="Reset" onAction="#handleResetFilters" prefHeight="38" prefWidth="80"/>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="reportsTable" prefHeight="320" VBox.vgrow="ALWAYS" styleClass="info-card">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Patient Name" prefWidth="130"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="140"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="100"/>
                    <TableColumn fx:id="diseaseColumn" text="Disease" prefWidth="110"/>
                    <TableColumn fx:id="heartRateColumn" text="HR (bpm)" prefWidth="80"/>
                    <TableColumn fx:id="oxygenColumn" text="O2 (%)" prefWidth="70"/>
                    <TableColumn fx:id="bpColumn" text="BP" prefWidth="80"/>
                    <TableColumn fx:id="tempColumn" text="Temp (°F)" prefWidth="80"/>
                    <TableColumn fx:id="sugarColumn" text="Sugar" prefWidth="70"/>
                    <TableColumn fx:id="urgencyColumn" text="Urgency" prefWidth="90"/>
                    <TableColumn fx:id="triageColumn" text="Triage" prefWidth="100"/>
                    <TableColumn fx:id="interventionColumn" text="Last Intervention" prefWidth="150"/>
                    <TableColumn fx:id="dateColumn" text="Recorded At" prefWidth="150"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <!-- Bottom Actions -->
            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 5px 0 0 0;">
                <Button text="Export to CSV" onAction="#handleExportCsv" styleClass="secondary-button" prefHeight="38" prefWidth="150"/>
                <Button text="Force Refresh" onAction="#handleRefresh" prefHeight="38" prefWidth="130"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Return to Dashboard" onAction="#handleBack" styleClass="primary-button" prefHeight="38" prefWidth="180"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- Async Loading Overlay -->
    <StackPane fx:id="loadingOverlay" visible="false" styleClass="loader-overlay">
        <VBox alignment="CENTER" spacing="15">
            <ProgressIndicator prefWidth="50" prefHeight="50" styleClass="progress-spinner"/>
            <Label text="Fetching telemetry reports..." styleClass="loader-text"/>
        </VBox>
    </StackPane>
</StackPane>
