<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.carewatch.features.monitoring.controller.DoctorLiveVitalsController">

    <!-- Workspace Panel VBox -->
    <VBox spacing="20" style="-fx-padding: 40px 30px 30px 30px;">
        
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Live Patient Vitals Monitor" styleClass="title-label"/>
                <Label text="Monitor telemetry vitals of all registered patients in real-time. Highlights critical vitals automatically." styleClass="subtitle-label"/>
            </VBox>
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="refreshStatusLabel" text="Auto-refresh Active (5s)" style="-fx-text-fill: #14b8a6; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-color: rgba(20,184,166,0.1); -fx-padding: 6px 12px; -fx-background-radius: 4px;"/>
            </HBox>
        </HBox>

        <!-- Filters & Search Bar Card -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="info-card" prefHeight="70">
            <TextField fx:id="searchField" promptText="Search name, email, or phone number..." HBox.hgrow="ALWAYS" prefHeight="38" onKeyReleased="#handleSearchKeyPress"/>
            <Button text="Search" onAction="#handleSearch" styleClass="primary-button" prefHeight="38" prefWidth="100"/>
            <Region style="-fx-pref-width: 15px;"/>
            <Label text="Urgency Status:" styleClass="body-label" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="urgencyFilterComboBox" onAction="#handleFilter" prefWidth="160" prefHeight="38"/>
            <Button text="Force Refresh" onAction="#handleRefreshManual" prefHeight="38" prefWidth="140"/>
        </HBox>

        <!-- Live Metrics Telemetry TableView -->
        <TableView fx:id="vitalsTable" VBox.vgrow="ALWAYS" styleClass="info-card">
            <columns>
                <TableColumn fx:id="patientIdColumn" text="Pat. ID" prefWidth="70"/>
                <TableColumn fx:id="nameColumn" text="Patient Name" prefWidth="150"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="130"/>
                <TableColumn fx:id="diseaseColumn" text="Disease / Diagnosis" prefWidth="150"/>
                <TableColumn fx:id="heartRateColumn" text="Heart Rate" prefWidth="100"/>
                <TableColumn fx:id="oxygenColumn" text="Oxygen" prefWidth="90"/>
                <TableColumn fx:id="bpColumn" text="BP (mmHg)" prefWidth="100"/>
                <TableColumn fx:id="tempColumn" text="Temp (°F)" prefWidth="100"/>
                <TableColumn fx:id="sugarColumn" text="Sugar" prefWidth="90"/>
                <TableColumn fx:id="urgencyColumn" text="Urgency" prefWidth="120"/>
                <TableColumn fx:id="dateColumn" text="Recorded At" prefWidth="160"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Bottom Footer Navigation -->
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10px 0 0 0;">
            <Button text="Return to Dashboard" onAction="#handleBack" styleClass="primary-button" prefWidth="200" prefHeight="38"/>
        </HBox>
    </VBox>

    <!-- Async Loading Overlay (Visible only on initial loads/critical actions) -->
    <StackPane fx:id="loadingOverlay" visible="false" styleClass="loader-overlay">
        <VBox alignment="CENTER" spacing="15">
            <ProgressIndicator prefWidth="50" prefHeight="50" styleClass="progress-spinner"/>
            <Label text="Syncing Telemetry Channels..." styleClass="loader-text"/>
        </VBox>
    </StackPane>
</StackPane>
