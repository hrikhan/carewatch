<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.carewatch.features.intervention.controller.InterventionController">

    <!-- Main Outer Container -->
    <VBox spacing="20" style="-fx-padding: 40px 30px 30px 30px;">
        
        <!-- Header -->
        <VBox spacing="5">
            <Label text="Patient Interventions Directory" styleClass="title-label"/>
            <Label text="Log clinical operations, telephone logs, prescriptions and advise notes for patients." styleClass="subtitle-label"/>
        </VBox>

        <!-- Horizontal workspace splits -->
        <HBox spacing="30" VBox.vgrow="ALWAYS">
            
            <!-- Left Side: Form Column -->
            <VBox spacing="20" minWidth="340" maxWidth="340">
                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Log New Intervention" styleClass="section-header"/>
                    
                    <!-- Patient Combo Box -->
                    <VBox spacing="6">
                        <Label text="Select Patient *" styleClass="body-label" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="patientComboBox" promptText="Choose Patient" maxWidth="Infinity" prefHeight="38"/>
                    </VBox>

                    <!-- Action Taken Combo Box -->
                    <VBox spacing="6">
                        <Label text="Action Taken *" styleClass="body-label" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="actionComboBox" promptText="Choose Clinical Action" maxWidth="Infinity" prefHeight="38" editable="true"/>
                    </VBox>

                    <!-- Notes Area -->
                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                        <Label text="Notes &amp; Details" styleClass="body-label"/>
                        <TextArea fx:id="notesArea" promptText="Provide context, advisory instructions, dosage details, or remarks..." VBox.vgrow="ALWAYS" wrapText="true"/>
                    </VBox>

                    <!-- Form Buttons -->
                    <VBox spacing="10">
                        <Button text="Save Action Note" onAction="#handleSave" styleClass="primary-button" maxWidth="Infinity" prefHeight="38"/>
                        <Button text="Clear Form" onAction="#handleClear" maxWidth="Infinity" prefHeight="36"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Right Side: Table Directory -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <!-- Filters Bar -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="info-card" prefHeight="70">
                    <TextField fx:id="searchField" promptText="Search patient name or email..." HBox.hgrow="ALWAYS" prefHeight="38" onKeyReleased="#handleSearchKeyPress"/>
                    <Button text="Search" onAction="#handleSearch" styleClass="primary-button" prefHeight="38" prefWidth="100"/>
                    <Region style="-fx-pref-width: 10px;"/>
                    <Label text="Physician:" styleClass="body-label" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="doctorFilterComboBox" onAction="#handleFilter" prefWidth="160" prefHeight="38"/>
                    <Button text="Refresh" onAction="#handleRefreshManual" prefHeight="38" prefWidth="100"/>
                </HBox>

                <!-- Data Table -->
                <TableView fx:id="interventionTable" VBox.vgrow="ALWAYS" styleClass="info-card">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="patientColumn" text="Patient Name" prefWidth="150"/>
                        <TableColumn fx:id="doctorColumn" text="Recorded By" prefWidth="140"/>
                        <TableColumn fx:id="actionColumn" text="Action Taken" prefWidth="150"/>
                        <TableColumn fx:id="notesColumn" text="Notes &amp; Details" prefWidth="250"/>
                        <TableColumn fx:id="dateColumn" text="Recorded At" prefWidth="160"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Return Button -->
                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10px 0 0 0;">
                    <Button text="Return to Dashboard" onAction="#handleBack" prefWidth="180" prefHeight="38"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>

    <!-- Async Loading Overlay -->
    <StackPane fx:id="loadingOverlay" visible="false" styleClass="loader-overlay">
        <VBox alignment="CENTER" spacing="15">
            <ProgressIndicator prefWidth="50" prefHeight="50" styleClass="progress-spinner"/>
            <Label text="Syncing Intervention Logs..." styleClass="loader-text"/>
        </VBox>
    </StackPane>
</StackPane>
