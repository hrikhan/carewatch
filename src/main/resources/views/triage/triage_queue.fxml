<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.carewatch.features.triage.controller.TriageQueueController">

    <!-- Workspace Panel -->
    <VBox spacing="20" style="-fx-padding: 40px 30px 30px 30px;">
        
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Clinical Triage Queue" styleClass="title-label"/>
                <Label text="Prioritize and resolve patients showing WARNING or CRITICAL vital metrics alerts." styleClass="subtitle-label"/>
            </VBox>
        </HBox>

        <!-- Filters Bar Card -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="info-card" prefHeight="70">
            <TextField fx:id="searchField" promptText="Search patient name or email..." HBox.hgrow="ALWAYS" prefHeight="38" onKeyReleased="#handleSearchKeyPress"/>
            <Button text="Search" onAction="#handleSearch" styleClass="primary-button" prefHeight="38" prefWidth="100"/>
            <Region style="-fx-pref-width: 15px;"/>
            <Label text="Filter Status:" styleClass="body-label" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="statusComboBox" onAction="#handleFilter" prefWidth="160" prefHeight="38"/>
            <Button text="Refresh" onAction="#handleRefreshManual" prefHeight="38" prefWidth="100"/>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="triageTable" VBox.vgrow="ALWAYS" styleClass="info-card">
            <columns>
                <TableColumn fx:id="idColumn" text="Queue ID" prefWidth="80"/>
                <TableColumn fx:id="nameColumn" text="Patient Name" prefWidth="150"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
                <TableColumn fx:id="diseaseColumn" text="Disease Type" prefWidth="140"/>
                <TableColumn fx:id="urgencyColumn" text="Urgency" prefWidth="110"/>
                <TableColumn fx:id="priorityColumn" text="Priority Score" prefWidth="110"/>
                <TableColumn fx:id="alertColumn" text="Alert Message" prefWidth="240"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                <TableColumn fx:id="dateColumn" text="Created At" prefWidth="160"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Bottom Controls -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10px 0 0 0;">
            <Button text="Return to Dashboard" onAction="#handleBack" prefWidth="180" prefHeight="38"/>
            <Button fx:id="btnResolve" text="Resolve Selected" onAction="#handleResolve" styleClass="primary-button" prefWidth="180" prefHeight="38"/>
        </HBox>
    </VBox>

    <!-- Async Loading Overlay -->
    <StackPane fx:id="loadingOverlay" visible="false" styleClass="loader-overlay">
        <VBox alignment="CENTER" spacing="15">
            <ProgressIndicator prefWidth="50" prefHeight="50" styleClass="progress-spinner"/>
            <Label text="Fetching Triage Alerts..." styleClass="loader-text"/>
        </VBox>
    </StackPane>
</StackPane>
